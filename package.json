{
  "name": "hubia-marketing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.js dev",
    "build": "node scripts/run-next.js build",
    "start": "node scripts/run-next.js start",
    "lint": "npm run i18n:check && npx tsc --noEmit",
    "i18n:check": "node scripts/validate-i18n.mjs",
    "i18n:audit-non-it": "node scripts/audit-non-it-italian.mjs",
    "clean": "rm -rf .next",
    "ci:check": "npm run i18n:check && npm run i18n:audit-non-it && npm run lint && npm run build",
    "generate-brand-icons": "node scripts/generate-brand-icons.js",
    "generate-brand-assets": "node scripts/generate-brand-assets.mjs",
    "generate-brand-from-photo": "node scripts/generate-brand-from-photo.mjs",
    "remove-bg-logo": "node scripts/remove-bg-from-logo.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.38",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0"
  }
}
